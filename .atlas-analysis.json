  "keyFeatures": [
    "Intent-based decentralized trading protocol",
    "Support for market swaps and limit orders",
    "Cross-chain token bridging with multiple providers",
    "Programmatic orders (TWAP, DCA, stop-loss)",
    "Smart contract wallet support with pre-sign",
    "Multiple blockchain adapter support (Viem, Ethers v5/v6)",
    "Partner fee integration",
    "Account abstraction with CoW Shed",
    "Order hooks for custom logic",
    "Multi-chain support across 11+ networks"
  ],
  "publicApiSurface": [
    "TradingSdk - Main trading interface with quote fetching and order posting",
    "OrderBookApi - Order book operations and trade retrieval",
    "OrderSigningUtils - Cryptographic signing for orders and cancellations",
    "MetadataApi - Order metadata and app-data management",
    "BridgingSdk - Cross-chain bridging with multi-provider quotes",
    "ConditionalOrderFactory - Programmatic order creation (TWAP, DCA)",
    "CowShedSdk - Account abstraction functionality",
    "ViemAdapter - Viem blockchain library adapter",
    "EthersV6Adapter - Ethers.js v6 adapter",
    "EthersV5Adapter - Ethers.js v5 adapter",
    "SupportedChainId - Chain configuration constants",
    "OrderKind - Order type enums (SELL/BUY)",
    "SigningScheme - Signature schemes (EIP712, PRESIGN, etc.)",
    "TradeParameters - Trading parameter types",
    "QuoteResults - Quote response structures"
  ]
}
